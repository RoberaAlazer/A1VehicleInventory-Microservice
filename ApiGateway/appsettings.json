{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApiGateway": {
    "ApiKey": "my-secret-key-12345"
  },
  "ReverseProxy": {
    "Routes": {
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/gateway/inventory/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/vehicles/{**catch-all}"
          }
        ]
      },
      "maintenance-route": {
        "ClusterId": "maintenance-cluster",
        "Match": {
          "Path": "/gateway/maintenance/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/maintenance/{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "inventory-cluster": {
        "Destinations": {
          "dest1": {
            "Address": "https://localhost:7288/"
          }
        }
      },
      "maintenance-cluster": {
        "Destinations": {
          "dest1": {
            "Address": "https://localhost:7270/"
          }
        }
      }
    }
  }
}